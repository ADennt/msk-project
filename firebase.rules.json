{
  "rules": {
    "products": {
      ".read": true,
      ".write": "auth != null && (auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com')",
      "$product": {
        ".validate": "newData.hasChildren(['id', 'name', 'type', 'typeLabel', 'variants'])"
      }
    },

    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com'",
        ".write": "$uid === auth.uid",
        "cart": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid",
          "$item": {
            ".validate": "newData.hasChildren(['id', 'name', 'price', 'quantity', 'size', 'film', 'image'])"
          }
        }
      }
    },

    "orders": {
      ".read": "auth != null && (auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com')",
      ".write": "auth != null",
      "$orderId": {
        ".read": "(auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com') || data.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['id', 'name', 'phone', 'email', 'address', 'items', 'total', 'status', 'createdAt', 'userId', 'type'])",
        "id": { ".validate": "newData.isNumber()" },
        "name": { ".validate": "newData.isString()" },
        "phone": { ".validate": "newData.isString()" },
        "email": { ".validate": "newData.isString()" },
        "address": { ".validate": "newData.isString()" },
        "items": { ".validate": "newData.isArray()" },
        "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "status": { ".validate": "newData.isString()" },
        "createdAt": { ".validate": "newData.isString()" },
        "userId": { ".validate": "newData.isString()" },
        "type": { ".validate": "newData.isString()" },
        "equipmentId": { ".validate": "newData.isString()" },
        "rentalStart": { ".validate": "newData.isString()" },
        "rentalEnd": { ".validate": "newData.isString()" }
      }
    },

    "equipment": {
      ".read": true,
      ".write": "auth != null && (auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com')",
      "$id": {
        ".validate": "newData.hasChildren(['name', 'category', 'dailyPrice', 'status'])"
      }
    },
    "equipment_bookings": {
      "$equipmentId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$bookingId": {
          ".validate": "newData.hasChildren(['start', 'end', 'orderId', 'userId']) && newData.child('userId').val() == auth.uid"
        }
      }
    },

    "meta": {
      ".read": "auth != null && (auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com')",
      ".write": "auth != null && (auth.token.email == 'admin@msk.ru' || auth.token.email == 'entelise@gmail.com')",
      "orderCounter": {
        ".validate": "newData.isNumber()"
      }
    }
  }
}