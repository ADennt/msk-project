{
  "rules": {
    "products": {
      ".read": true,
      ".write": "auth != null && auth.token.email in ['admin@msk.ru', 'entelise@gmail.com']",
      "$product": {
        ".validate": "newData.hasChildren(['id', 'name', 'type', 'typeLabel', 'variants'])",
        "id": { ".validate": "newData.isNumber()" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "type": { ".validate": "newData.isString()" },
        "typeLabel": { ".validate": "newData.isString()" },
        "tag": { ".validate": "newData.isString()" },
        "image": { ".validate": "newData.isString()" },
        "description": { ".validate": "newData.isString()" },
        "inStock": { ".validate": "newData.isNumber()" },
        "characteristics": {
          ".validate": "newData.hasChildren(['material'])",
          "material": { ".validate": "newData.isString()" }
        },
        "variants": {
          ".validate": "newData.isArray() && newData.val().length > 0",
          "$variant": {
            ".validate": "newData.hasChildren(['size', 'film', 'price'])",
            "size": { ".validate": "newData.isString()" },
            "film": { ".validate": "newData.isString()" },
            "price": { ".validate": "newData.isNumber() && newData.val() > 0" }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid || auth.token.email in ['admin@msk.ru', 'entelise@gmail.com']",
        ".write": "$uid === auth.uid",
        "cart": {
          ".read": "$uid === auth.uid",
          ".write": "$uid === auth.uid",
          "$item": {
            ".validate": "newData.hasChildren(['id', 'name', 'price', 'quantity', 'size', 'film', 'image'])",
            "id": { ".validate": "newData.isNumber()" },
            "name": { ".validate": "newData.isString()" },
            "price": { ".validate": "newData.isNumber() && newData.val() > 0" },
            "quantity": { ".validate": "newData.isNumber() && newData.val() > 0" },
            "size": { ".validate": "newData.isString()" },
            "film": { ".validate": "newData.isString()" },
            "image": { ".validate": "newData.isString()" }
          }
        },
        "email": { ".validate": "newData.isString()" },
        "registeredAt": { ".validate": "newData.isString()" },
        "uid": { ".validate": "newData.isString()" }
      }
    },
    "orders": {
      ".read": "auth != null && auth.token.email in ['admin@msk.ru', 'entelise@gmail.com']",
      ".write": "auth != null",
      "$orderId": {
        ".read": "auth.token.email in ['admin@msk.ru', 'entelise@gmail.com'] || data.child('userId').val() === auth.uid",
        ".validate": "newData.hasChildren(['id', 'name', 'phone', 'email', 'address', 'items', 'total', 'status', 'createdAt', 'userId'])",
        "id": { ".validate": "newData.isNumber()" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0" },
        "phone": { ".validate": "newData.isString()" },
        "email": { ".validate": "newData.isString()" },
        "address": { ".validate": "newData.isString()" },
        "items": {
          ".validate": "newData.isArray()",
          "$item": {
            ".validate": "newData.hasChildren(['id', 'name', 'price', 'quantity', 'size', 'film', 'image'])"
          }
        },
        "total": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "status": {
          ".validate": "newData.isString() && newData.val().matches('новый|в обработке|отправлен|доставлен|отменён')"
        },
        "createdAt": { ".validate": "newData.isString()" },
        "userId": {
          ".validate": "newData.isString() && newData.val() === auth.uid"
        }
      }
    },
    "meta": {
      ".read": "auth != null && auth.token.email in ['admin@msk.ru', 'entelise@gmail.com']",
      ".write": "auth != null && auth.token.email in ['admin@msk.ru', 'entelise@gmail.com']",
      "orderCounter": {
        ".validate": "newData.isNumber()"
      }
    }
  }
}